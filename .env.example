# Copy this to .env for local development (never commit .env to git)

# Google OAuth credentials (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Your app's public URL
# Local:       http://localhost:8080
# Cloud Run:   https://paypal-dashboard-xxxxx-uc.a.run.app
BASE_URL=http://localhost:8080

# Strong random string — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-string
